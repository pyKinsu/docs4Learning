{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "pyKinsu Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Home",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          }
        ]
      },
      {
        "tab": "C Language",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "c-language/introduction"
            ]
          },
          {
            "group": "Getting Started",
            "pages": [
              "c-language/getting-started/overview",
              "c-language/getting-started/setup",
              "c-language/getting-started/first-program"
            ]
          },
          {
            "group": "Basics",
            "pages": [
              "c-language/basics/variables",
              "c-language/basics/data-types",
              "c-language/basics/operators",
              "c-language/basics/input-output"
            ]
          },
          {
            "group": "Control Flow",
            "pages": [
              "c-language/control-flow/conditionals",
              "c-language/control-flow/loops",
              "c-language/control-flow/switch"
            ]
          },
          {
            "group": "Functions",
            "pages": [
              "c-language/functions/defining-functions",
              "c-language/functions/recursion",
              "c-language/functions/scope"
            ]
          },
          {
            "group": "Arrays & Strings",
            "pages": [
              "c-language/arrays-strings/arrays",
              "c-language/arrays-strings/strings"
            ]
          },
          {
            "group": "Pointers",
            "pages": [
              "c-language/pointers/introduction",
              "c-language/pointers/pointer-arithmetic"
            ]
          },
          {
            "group": "Memory Management",
            "pages": [
              "c-language/memory/stack-heap",
              "c-language/memory/dynamic-memory"
            ]
          }
        ]
      },
      {
        "tab": "Examples",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "examples/index"
            ]
          },
          {
            "group": "C Language",
            "pages": [
              "examples/c-language/hello-world",
              "examples/c-language/fibonacci",
              "examples/c-language/factorial",
              "examples/c-language/reverse-string",
              "examples/c-language/linked-list"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/pyKinsu/docs",
          "icon": "github"
        },
        {
          "anchor": "Mintlify Docs",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/pyKinsu"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/pykinsu",
      "github": "https://github.com/pyKinsu"
    }
  }
